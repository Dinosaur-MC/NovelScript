# ============================================================================
# NovelScript (析幕) — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# Never commit .env to version control!
#
# ═══ Quick Start ════════════════════════════════════════════════════════════
#
#   Dev server (FastAPI) — .env is auto-loaded via pydantic-settings:
#     uv run main.py
#
#   Pipeline CLI — .env is auto-loaded via python-dotenv on startup:
#     uv run python -m cli.pipeline sample.txt
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL — All-in-One Database
# ----------------------------------------------------------------------------
# Connection string for psycopg2 (sync driver, no event-loop issues):
#   postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://novelscript:novelscript@localhost:5432/novelscript

# ----------------------------------------------------------------------------
# AI / LLM — Novel-to-Script Conversion
# ----------------------------------------------------------------------------
# DeepSeek API key for chat completions (Stage 1 Planning + Stage 2 Conversion
# + Stage 3 Optimization). Get yours at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ----------------------------------------------------------------------------
# OpenRouter — Embedding Service (RAG Vectorization)
# ----------------------------------------------------------------------------
# OpenAI-compatible embeddings endpoint.
# Docs: https://openrouter.ai/docs/client-sdks/python/api-reference/embeddings
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# ----------------------------------------------------------------------------
# Redis / Celery — Background Task Queue
# ----------------------------------------------------------------------------
# Redis connection string used by Celery as both the message broker and
# result backend.  The same URL is read by FastAPI to poll task progress
# via AsyncResult(task_id).
#   - Install Redis: https://redis.io/download
#   - Start: redis-server
#   - Default db 0 is fine for a single-app instance
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# LLM Tuning — context limits, concurrency, retries
# ----------------------------------------------------------------------------
# Override the auto-detected context window (tokens).  When unset the limit
# is inferred from the model name (DeepSeek V4 = 1 000 000 tokens).
# LLM_CONTEXT_WINDOW=128000
#
# Override the auto-detected max output tokens.
# LLM_MAX_OUTPUT_TOKENS=8192
#
# Maximum concurrent LLM API calls across ALL pipeline stages (default: 20).
# Also settable via the CLI:  uv run python -m cli.pipeline ... -c 50
# DeepSeek limits: Pro=500, Flash=2500 — the default is conservative on purpose.
# LLM_MAX_CONCURRENCY=20
#
# Maximum retries per LLM call before giving up (default: per-stage, 1-3).
# LLM_MAX_RETRIES=3

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
# Set to true for debug logging, tracebacks in error responses, and
# uvicorn --reload auto-restart.
DEBUG=false

# ----------------------------------------------------------------------------
# Admin Account — seeded on first startup
# ----------------------------------------------------------------------------
# Set via environment or docker-compose.yml.  Only takes effect when no
# admin user (role='admin') exists yet in the database.
ADMIN_EMAIL=admin@novelscript.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=Administrator
