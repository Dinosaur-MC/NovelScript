# ============================================================================
# NovelScript (析幕) — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# Never commit .env to version control!
#
# ═══ Quick Start ════════════════════════════════════════════════════════════
#
#   Dev server (FastAPI) — .env is auto-loaded via pydantic-settings:
#     uv run main.py
#
#   Pipeline CLI — .env is NOT auto-loaded; source it first:
#     set -a && source .env && set +a          # Linux / WSL / Git Bash
#     uv run python -m cli.pipeline sample.txt
#
#     Or with PowerShell:
#     Get-Content .env | ForEach-Object {
#       if ($_ -match '^([^#].+?)=(.+)$') {
#         [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process')
#       }
#     }
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL — All-in-One Database
# ----------------------------------------------------------------------------
# Connection string for asyncpg:
#   postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Default: localhost:5432, db=novelscript, user=novelscript
DATABASE_URL=postgresql+asyncpg://novelscript:novelscript@localhost:5432/novelscript

# ----------------------------------------------------------------------------
# AI / LLM — Novel-to-Script Conversion
# ----------------------------------------------------------------------------
# DeepSeek API key for chat completions (Stage 1 Planning + Stage 2 Conversion
# + Stage 3 Optimization). Get yours at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ----------------------------------------------------------------------------
# OpenRouter — Embedding Service (RAG Vectorization)
# ----------------------------------------------------------------------------
# OpenAI-compatible embeddings endpoint.
# Docs: https://openrouter.ai/docs/client-sdks/python/api-reference/embeddings
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
# Set to true for debug logging, tracebacks in error responses, and
# uvicorn --reload auto-restart.
DEBUG=false
